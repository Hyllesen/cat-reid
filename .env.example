# RTSP stream URL (e.g., rtsp://192.168.1.100:554/stream)
RTSP_URL=rtsp://your-camera-ip:554/stream

# Path to yolo26n model
MODEL_PATH=yolo26n.pt

# Output directory for cropped cat images (relative path: ./data/raw_crops/ or absolute path)
OUTPUT_DIR=./data/raw_crops/

# Confidence threshold for cat detections (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.7

# Maximum reconnection attempts before giving up
MAX_RECONNECT_ATTEMPTS=10

# Delay in seconds between reconnection attempts
RECONNECT_DELAY=5

# Frame processing interval (process every Nth frame to reduce load)
FRAME_SKIP=1

# Enable debug logging
DEBUG=False
