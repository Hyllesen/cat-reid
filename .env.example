# ── Stream ────────────────────────────────────────────────────────────────────
RTSP_URL=rtsp://<user>:<pass>@<camera-ip>:554/stream1

# ── Trigger endpoint ──────────────────────────────────────────────────────────
TRIGGER_URL=http://<horn-ip>/trigger

# ── Models ────────────────────────────────────────────────────────────────────
DETECTOR_MODEL=yolo26n.pt
CLASSIFIER_MODEL=cat_color_classifier.mlpackage

# ── Thresholds ────────────────────────────────────────────────────────────────
DETECT_CONF=0.5
CLASSIFY_CONF=0.8
GREY_MAJORITY=10
DEQUE_LEN=15
COOLDOWN_SECONDS=5

# ── Output ────────────────────────────────────────────────────────────────────
DETECTIONS_DIR=detections
